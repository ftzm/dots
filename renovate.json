{
   "$schema": "https://docs.renovatebot.com/renovate-schema.json",
   "customManagers": [
      {
         "customType": "regex",
         "datasourceTemplate": "helm",
         "depNameTemplate": "nfs-subdir-external-provisioner",
         "managerFilePatterns": [
            "/cluster/chartfile\\.yaml$/"
         ],
         "matchStrings": [
            "- chart: nfs-subdir-external-provisioner/nfs-subdir-external-provisioner\\s+version: \"?(?<currentValue>[^\"\\s]+)\"?"
         ],
         "registryUrlTemplate": "https://kubernetes-sigs.github.io/nfs-subdir-external-provisioner/"
      },
      {
         "customType": "regex",
         "datasourceTemplate": "helm",
         "depNameTemplate": "traefik",
         "managerFilePatterns": [
            "/cluster/chartfile\\.yaml$/"
         ],
         "matchStrings": [
            "- chart: traefik/traefik\\s+version: \"?(?<currentValue>[^\"\\s]+)\"?"
         ],
         "registryUrlTemplate": "https://traefik.github.io/charts"
      },
      {
         "customType": "regex",
         "datasourceTemplate": "helm",
         "depNameTemplate": "argo-cd",
         "managerFilePatterns": [
            "/cluster/chartfile\\.yaml$/"
         ],
         "matchStrings": [
            "- chart: argo/argo-cd\\s+version: \"?(?<currentValue>[^\"\\s]+)\"?"
         ],
         "registryUrlTemplate": "https://argoproj.github.io/argo-helm"
      },
      {
         "customType": "regex",
         "datasourceTemplate": "helm",
         "depNameTemplate": "kube-prometheus-stack",
         "managerFilePatterns": [
            "/cluster/chartfile\\.yaml$/"
         ],
         "matchStrings": [
            "- chart: prometheus-community/kube-prometheus-stack\\s+version: \"?(?<currentValue>[^\"\\s]+)\"?"
         ],
         "registryUrlTemplate": "https://prometheus-community.github.io/helm-charts"
      },
      {
         "customType": "regex",
         "datasourceTemplate": "helm",
         "depNameTemplate": "loki",
         "managerFilePatterns": [
            "/cluster/chartfile\\.yaml$/"
         ],
         "matchStrings": [
            "- chart: grafana/loki\\s+version: \"?(?<currentValue>[^\"\\s]+)\"?"
         ],
         "registryUrlTemplate": "https://grafana.github.io/helm-charts"
      },
      {
         "customType": "regex",
         "datasourceTemplate": "helm",
         "depNameTemplate": "tempo",
         "managerFilePatterns": [
            "/cluster/chartfile\\.yaml$/"
         ],
         "matchStrings": [
            "- chart: grafana-community/tempo\\s+version: \"?(?<currentValue>[^\"\\s]+)\"?"
         ],
         "registryUrlTemplate": "https://grafana-community.github.io/helm-charts"
      },
      {
         "customType": "regex",
         "datasourceTemplate": "helm",
         "depNameTemplate": "alloy",
         "managerFilePatterns": [
            "/cluster/chartfile\\.yaml$/"
         ],
         "matchStrings": [
            "- chart: grafana/alloy\\s+version: \"?(?<currentValue>[^\"\\s]+)\"?"
         ],
         "registryUrlTemplate": "https://grafana.github.io/helm-charts"
      },
      {
         "customType": "regex",
         "datasourceTemplate": "helm",
         "depNameTemplate": "sealed-secrets",
         "managerFilePatterns": [
            "/cluster/chartfile\\.yaml$/"
         ],
         "matchStrings": [
            "- chart: sealed-secrets/sealed-secrets\\s+version: \"?(?<currentValue>[^\"\\s]+)\"?"
         ],
         "registryUrlTemplate": "https://bitnami-labs.github.io/sealed-secrets"
      },
      {
         "customType": "regex",
         "datasourceTemplate": "helm",
         "depNameTemplate": "cert-manager",
         "managerFilePatterns": [
            "/cluster/chartfile\\.yaml$/"
         ],
         "matchStrings": [
            "- chart: jetstack/cert-manager\\s+version: \"?(?<currentValue>[^\"\\s]+)\"?"
         ],
         "registryUrlTemplate": "https://charts.jetstack.io"
      },
      {
         "customType": "regex",
         "datasourceTemplate": "helm",
         "depNameTemplate": "sops-secrets-operator",
         "managerFilePatterns": [
            "/cluster/chartfile\\.yaml$/"
         ],
         "matchStrings": [
            "- chart: sops-secrets-operator/sops-secrets-operator\\s+version: \"?(?<currentValue>[^\"\\s]+)\"?"
         ],
         "registryUrlTemplate": "https://isindir.github.io/sops-secrets-operator/"
      }
   ],
   "enabledManagers": [
      "custom.regex",
      "github-actions",
      "jsonnet-bundler"
   ],
   "extends": [
      "config:recommended"
   ],
   "postUpgradeTasks": {
      "commands": [
         "cd cluster && tk tool charts vendor --prune",
         "cd cluster && just render-lab"
      ],
      "fileFilters": [
         "cluster/charts/**",
         "cluster/manifests/**"
      ]
   },
   "prConcurrentLimit": 20,
   "prHourlyLimit": 10
}
