# Render all environments
render-all: render-lab

# Render lab environment.
# Render into a temp dir and swap only on success: a failed render must not
# leave manifests/lab empty (renovate commits whatever the tree looks like
# after its post-upgrade task, and an empty tree would delete everything).
render-lab:
    #!/usr/bin/env bash
    set -euo pipefail
    tmp=$(mktemp -d manifests/.render-lab.XXXXXX)
    trap 'rm -rf "$tmp"' EXIT
    tk export "$tmp" environments/lab --format '{{ "{{" }}.metadata.name{{ "}}" }}-{{ "{{" }}.kind | lower{{ "}}" }}' --skip-manifest
    cp environments/lab/secrets/*.enc.yaml "$tmp"/
    rm -rf manifests/lab
    mv "$tmp" manifests/lab

# Initialize jsonnet-bundler dependencies
jb-install:
    jb install

# Update jsonnet-bundler dependencies
jb-update:
    jb update

# Show diff of what would change in lab
diff-lab:
    tk diff environments/lab

# Generate renovate.json from chartfile.yaml (outputs to repo root)
generate-renovate:
    jsonnet renovate.jsonnet > ../renovate.json
    renovate-config-validator ../renovate.json

# Test renovate config locally (dry-run)
test-renovate:
    RENOVATE_CONFIG_FILE=renovate.json renovate --platform=local --dry-run=full --onboarding=false
